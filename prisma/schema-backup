generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  OPEN
  CLOSED
  DELETED
}

enum EnrollmentStatus {
  STUDYING
  COMPLETED
  CANCELLED
}

enum ActivityType {
  STUDENT_CREATED
  TEACHER_CREATED
  COURSE_CREATED
  STUDENT_ENROLLED
}

model User {
  id            String    @id @default(uuid())

  email         String    @unique
  password      String

  fullName      String?
  phone         String?
  address       String?

  avatarUrl     String?

  dateOfBirth   DateTime?
  gender        Gender?

  lastLoginAt   DateTime?

  role          Role      @default(STUDENT)
  status        Status    @default(ACTIVE)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student       Student?
  teacher       Teacher?

  @@map("users")
}

model Student {
  id                    String    @id @default(uuid())

  userId                String    @unique

  // mã học viên nội bộ
  studentCode           String    @unique

  // thông tin phụ huynh
  parentName            String?
  parentPhone           String?

  // trường / lớp hiện tại
  schoolName            String?
  grade                 String?

  // trình độ đầu vào
  entryAcademicLevel    String?

  // điểm gần nhất
  latestTestScore       Float?

  // mục tiêu học
  learningGoal          String?

  // ghi chú nội bộ
  note                  String?

  // ngày tham gia
  joinedAt              DateTime? @default(now())

  // relation
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  enrollments           Enrollment[]

  @@map("students")
}

model Teacher {
  id                    String    @id @default(uuid())

  userId                String    @unique

  // mã giáo viên nội bộ
  teacherCode           String    @unique

  // giới thiệu
  bio                   String?

  // chuyên môn
  specialization        String?

  // bằng cấp
  qualification         String?

  // số năm kinh nghiệm
  yearsOfExperience     Int?

  // trạng thái nhận lớp
  isAvailable           Boolean   @default(true)

  // ngày vào làm
  joinedAt              DateTime? @default(now())

  // ghi chú nội bộ
  note                  String?

  // relation
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  courses               Course[]

  @@map("teachers")
}

model Course {
  id                    String              @id @default(uuid())

  // mã khóa học nội bộ
  courseCode                  String              @unique

  // tên khóa học
  name                  String

  // mô tả
  description           String?

  // ảnh thumbnail
  thumbnailUrl          String?

  // trình độ khóa học
  level                 CourseLevel?

  // giá niêm yết
  price                 Float?

  // tổng số buổi học
  totalSessions         Int?

  // Tổng số học viên
  maxStudents           Int?

  // ngày bắt đầu
  startDate             DateTime?

  // ngày kết thúc
  endDate               DateTime?

  // Giờ bắt đầu
  startTime             String?

  // Giờ kết thúc
  endTime               String?

  // trạng thái khóa học
  status                CourseStatus        @default(DRAFT)

  // giáo viên phụ trách
  teacherId             String?

  // timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // relation
  teacher               Teacher?            @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  enrollments           Enrollment[]

  @@map("courses")
}

model Enrollment {
  id                    String              @id @default(uuid())

  studentId             String
  courseId              String

  // snapshot giá khóa học lúc đăng ký
  originalPrice         Float?

  // số tiền thực tế đã đóng
  paidAmount            Float?

  // trạng thái học
  status                EnrollmentStatus    @default(STUDYING)

  // ngày đăng ký
  enrolledAt            DateTime            @default(now())

  // ghi chú
  note                  String?

  // timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // relation
  student               Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  course                Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // 1 học viên không được đăng ký trùng 1 khóa
  @@unique([studentId, courseId])

  @@map("enrollments")
}

model ActivityLog {
  id          String       @id @default(uuid())

  type        ActivityType

  title       String
  description String?

  createdAt   DateTime     @default(now())

  @@map("activity_logs")
}